        <!-- ilmControl API code example -->
        <mxCell id="code" value="// あなたのコード（HMI マネージャ）に書くのはこれだけ&#xa;#include &lt;ilm/ilmControl.h&gt;&#xa;&#xa;// 初期化&#xa;ilmErrorTypes result = ilm_init();&#xa;&#xa;// サーフェスをレイヤーに追加&#xa;ilm_layerAddSurface(MY_LAYER_ID, surfaceId);&#xa;&#xa;// 表示位置・サイズを設定&#xa;ilm_surfaceSetDestinationRectangle(surfaceId, 0, 0, 800, 480);&#xa;&#xa;// 表示・非表示の切替&#xa;ilm_surfaceSetVisibility(surfaceId, ILM_TRUE);&#xa;&#xa;// 確定（ここで Weston に反映される）&#xa;ilm_commitChanges();" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontFamily=Courier New;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="590" y="450" width="530" height="310" as="geometry" />
        </mxCell>

