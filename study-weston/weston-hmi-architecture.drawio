        <!-- Bottom: code example of using AGL WM API -->
        <mxCell id="codet" value="アプリ側のコード例（libwindowmanager を使う）" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="548" width="500" height="25" as="geometry" />
        </mxCell>
        <mxCell id="code1" value="#include &lt;libwindowmanager.h&gt;&#xa;&#xa;LibWindowmanager *wm = new LibWindowmanager();&#xa;wm-&gt;init(port, token);&#xa;&#xa;// 「このアプリを表示したい」と要求するだけ&#xa;wm-&gt;requestSurface(appid);&#xa;&#xa;// 「前面になった」通知を受け取るコールバック&#xa;wm-&gt;set_event_handler(LibWindowmanager::Event_Active,&#xa;    [](json_object *j) { /* 前面になった時の処理 */ });" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontFamily=Courier New;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="578" width="520" height="205" as="geometry" />
        </mxCell>

        <mxCell id="codet2" value="③ポリシー層から WindowManager を呼ぶコード例" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="548" width="520" height="25" as="geometry" />
        </mxCell>
        <mxCell id="code2" value="// CAN イベント「リバースギア検知」を受けたポリシー層が呼ぶ&#xa;void PolicyLayer::onReverseGear() {&#xa;    // WindowManager API でバックカメラを前面に&#xa;    windowManager-&gt;activateSurface(BACKCAMERA_APP_ID);&#xa;&#xa;    // または直接 ilmControl を使う（安全系は直接制御）&#xa;    ilm_layerSetVisibility(LAYER_WARNING, ILM_TRUE);&#xa;    ilm_surfaceSetVisibility(BACKCAM_SURFACE, ILM_TRUE);&#xa;    ilm_commitChanges();&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontFamily=Courier New;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="610" y="578" width="520" height="205" as="geometry" />
