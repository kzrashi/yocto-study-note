          <mxGeometry x="710" y="105" width="280" height="55" as="geometry" />
        </mxCell>

        <mxCell id="a1" value="ilm_layerSetVisibility(LAYER_WARNING, ILM_TRUE);" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontFamily=Courier New;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="210" width="510" height="35" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="ilm_surfaceSetDestinationRectangle(surfaceId, x, y, w, h);" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontFamily=Courier New;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="255" width="510" height="35" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="ilm_layerSetRenderOrder(layerId, surfaceIds, count);" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontFamily=Courier New;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="300" width="510" height="35" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="ilm_commitChanges();" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;fontFamily=Courier New;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="345" width="510" height="35" as="geometry" />
        </mxCell>

        <mxCell id="ae" value="" style="endArrow=block;endFill=1;strokeColor=#d79b00;" edge="1" parent="1" source="ilm" target="a1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="g1" value="🔑 設計上の保証&#xa;&#xa;Layer 3 に割り当てられたサーフェスは&#xa;Layer 0〜2 のどのアプリが動いていても&#xa;必ず最前面に表示される。&#xa;&#xa;「警告が見えない」という事故を&#xa;設計レベルで防止できる。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="420" width="510" height="165" as="geometry" />
        </mxCell>

        <mxCell id="g2" value="📌 Desktop Shell との違い&#xa;Desktop Shell にはレイヤー番号の概念がない。&#xa;ウィンドウの重なりはユーザー操作で変わるため、&#xa;安全情報の常時表示を保証できない。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="605" width="510" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
