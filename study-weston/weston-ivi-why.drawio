        <mxCell id="ie6" value="レンダリング" style="endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1" source="i6" target="i7"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- API code detail -->
        <mxCell id="code" value="// ナビのサーフェスをレイヤー1の前面に表示&#xa;ilm_layerAddSurface(LAYER_APP, NAV_SURFACE_ID);&#xa;ilm_surfaceSetDestinationRectangle(NAV_SURFACE_ID, 0, 0, 800, 480);&#xa;ilm_surfaceSetVisibility(NAV_SURFACE_ID, ILM_TRUE);&#xa;ilm_commitChanges();" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;fontFamily=Courier New;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="640" height="125" as="geometry" />
        </mxCell>

        <!-- Key point -->
        <mxCell id="kp" value="🔑 ポイント&#xa;&#xa;Desktop Shell では画面切り替えは&#xa;「ユーザーのクリック」で起きる。&#xa;&#xa;IVI Shell では画面切り替えは&#xa;「ミドルウェアの命令」で起きる。&#xa;&#xa;ドライバーが画面を操作しなくても、&#xa;ナビ・空調・電話が自動的に&#xa;適切な位置・順序で表示される。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="365" width="390" height="250" as="geometry" />
        </mxCell>

